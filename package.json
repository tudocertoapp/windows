{
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8081",
    "web:build": "expo export --platform web && node scripts/ensure-dist-assets.js && node scripts/patch-web-index.js && node scripts/patch-web-bundle-assets.js",
    "sync:desktop-version": "node scripts/set-desktop-version.js",
    "sync:mobile-version": "node scripts/set-mobile-version.js",
    "electron:icon": "node scripts/gen-electron-icon.js",
    "electron:dev": "cross-env ELECTRON_DEV=1 electron electron/main.js",
    "electron:dev:all": "concurrently -k \"npm run web\" \"wait-on tcp:8081 && npm run electron:dev\"",
    "electron:pack:win": "npm run sync:desktop-version && npm run electron:icon && npm run web:build && electron-builder --win --x64 --publish never",
    "electron:pack:win:ia32": "npm run sync:desktop-version && npm run electron:icon && npm run web:build && electron-builder --win --ia32 --publish never",
    "electron:pack:linux": "npm run sync:desktop-version && npm run electron:icon && npm run web:build && electron-builder --linux AppImage deb --x64 --publish never",
    "electron:pack:mac": "npm run sync:desktop-version && npm run electron:icon && npm run web:build && electron-builder --mac dmg zip --x64 --publish never",
    "build:win": "npm run electron:pack:win",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-voice/voice": "^3.2.4",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.12.2",
    "electron-updater": "^6.8.3",
    "expo": "^54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "stripe": "^17.7.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "react-native-worklets": "0.5.1",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.0",
    "patch-package": "^8.0.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-voice/voice"
        ]
      }
    }
  },
  "private": true,
  "name": "tudo-certo",
  "version": "1.0.13",
  "build": {
    "artifactName": "Tudo-Certo-Setup-${version}.${ext}",
    "appId": "com.tudocerto.desktop",
    "productName": "Tudo Certo",
    "copyright": "Copyright © Tudo Certo",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "tudocertoapp",
      "repo": "windows"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/icon.png",
      "electron/icon-256.png",
      "electron/icon.ico",
      "electron/icon.icns",
      "electron/icons/**/*"
    ],
    "asarUnpack": [
      "dist/assets/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.ico"
    },
    "mac": {
      "icon": "electron/icon.icns"
    },
    "linux": {
      "icon": "electron/icons"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "guid": "6a87a150-9f77-4dd8-b149-8d9be5f1f0d3",
      "include": "build/installer.nsh",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "runAfterFinish": true
    }
  }
}
